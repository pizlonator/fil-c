# PAM configuration for /opt/fil sshd
#
# Minimal configuration using core PAM modules built with Fil-C.
# This provides basic authentication, account validation, and session setup.

# Authentication - verify user credentials
auth       required   pam_unix.so

# Account management - check account validity (not expired, not locked, etc)
account    required   pam_unix.so

# Session management - setup user environment
session    required   pam_unix.so
session    required   pam_loginuid.so
session    required   pam_env.so
session    required   pam_limits.so
session    optional   pam_motd.so

# Password management - for password changes
password   required   pam_unix.so
