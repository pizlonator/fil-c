	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_HEADER) $$files '$(DESTDIR)$(libenchant_includedir)'"; \
	  $(INSTALL_HEADER) $$files "$(DESTDIR)$(libenchant_includedir)" || exit $$?; \
	done

