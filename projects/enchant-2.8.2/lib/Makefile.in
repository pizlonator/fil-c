	-rm -f ./$(DEPDIR)/libenchant_@ENCHANT_MAJOR_VERSION@_la-provider.Plo
	-rm -f ./$(DEPDIR)/libenchant_@ENCHANT_MAJOR_VERSION@_la-pwl.Plo
	-rm -f ./$(DEPDIR)/libenchant_@ENCHANT_MAJOR_VERSION@_la-session.Plo
	-rm -f ./$(DEPDIR)/libenchant_@ENCHANT_MAJOR_VERSION@_la-util.Plo
	-rm -f Makefile
maintainer-clean-am: distclean-am maintainer-clean-generic

mostlyclean: mostlyclean-am

mostlyclean-am: mostlyclean-compile mostlyclean-generic \
	mostlyclean-libtool

pdf: pdf-am

pdf-am:

ps: ps-am

ps-am:

uninstall-am: uninstall-libLTLIBRARIES uninstall-libenchant_dataDATA \
	uninstall-libenchant_includeHEADERS uninstall-man \
	uninstall-nodist_docDATA

uninstall-man: uninstall-man5

.MAKE: all check install install-am install-exec install-strip

.PHONY: CTAGS GTAGS TAGS all all-am am--depfiles check check-am clean \
	clean-generic clean-libLTLIBRARIES clean-libtool cscopelist-am \
	ctags ctags-am distclean distclean-compile distclean-generic \
	distclean-libtool distclean-tags distdir dvi dvi-am html \
	html-am info info-am install install-am install-data \
	install-data-am install-dvi install-dvi-am install-exec \
	install-exec-am install-html install-html-am install-info \
	install-info-am install-libLTLIBRARIES \
	install-libenchant_dataDATA install-libenchant_includeHEADERS \
	install-man install-man5 install-nodist_docDATA install-pdf \
	install-pdf-am install-ps install-ps-am install-strip \
	installcheck installcheck-am installdirs maintainer-clean \
	maintainer-clean-generic mostlyclean mostlyclean-compile \
	mostlyclean-generic mostlyclean-libtool pdf pdf-am ps ps-am \
	tags tags-am uninstall uninstall-am uninstall-libLTLIBRARIES \
	uninstall-libenchant_dataDATA \
	uninstall-libenchant_includeHEADERS uninstall-man \
	uninstall-man5 uninstall-nodist_docDATA

.PRECIOUS: Makefile


dummy.vala: $(VAPIS)
	touch $@

enchant.5: $(builddir)/enchant.5.in Makefile.am $(top_builddir)/config.status
	rm -f $@ $@.tmp
	$(edit) $(abs_builddir)/enchant.5.in >$@.tmp
	mv $@.tmp $@

enchant.html: enchant.5
	groff -mandoc -Thtml $< > $@

# Tell versions [3.59,3.63) of GNU make to not export all variables.
# Otherwise a system limit (for SysV at least) may be exceeded.
.NOEXPORT:
