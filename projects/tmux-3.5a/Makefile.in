	$(top_srcdir)/compat/getdtablesize.c \
	$(top_srcdir)/compat/getline.c $(top_srcdir)/compat/getopt.c \
	$(top_srcdir)/compat/getpeereid.c \
	$(top_srcdir)/compat/getprogname.c \
	$(top_srcdir)/compat/htonll.c \
